# Redirect /index.html to canonical root — prevents Google flagging it as a redirect page
/index.html / 301

# Redirect old /blog/:slug URLs to correct article URL format
/blog/:slug /article?slug=:slug 301

# Redirect /vip-discord (hyphenated) to correct URL
/vip-discord /vipdiscord 301

# Redirect old versioned privacy URL
/privacy-v11 /privacy 301

# Retired variant pages (existed on old main, removed at cutover) → 301 to their
# canonical live pages (matches the pages' own canonical tags; hard-constraint:
# a removed public URL must be 301'd).
/vipdiscord2 /vipdiscord 301
/vipdiscord2.html /vipdiscord 301
/waitlist2 /waitlist 301
/waitlist2.html /waitlist 301
